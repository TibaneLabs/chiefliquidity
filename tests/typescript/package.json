{
  "name": "chiefliquidity-tests",
  "version": "1.0.0",
  "description": "E2E tests for ChiefLiquidity program",
  "scripts": {
    "test": "npm run test:functional && npm run test:adversarial && npm run test:benchmark",
    "test:functional": "npx ts-node --transpile-only test_liquidity.ts",
